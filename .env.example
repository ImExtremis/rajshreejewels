# =============================================================================
# 💎 Rajshree Jewels — Complete Production Environment Configuration Template
# =============================================================================

# ─── CORE SERVER SETTINGS ────────────────────────────────────────────────────
NODE_ENV=production
PORT=4000
FRONTEND_URL=https://rajshreejewels.com
ADMIN_URL=http://localhost:3001

# Database
DB_USER=postgres
DB_PASSWORD=change_this_strong_password
DATABASE_URL=postgresql://postgres:change_this_strong_password@postgres:5432/jewellery_store

# Redis
REDIS_PASSWORD=change_this_redis_password
REDIS_URL=redis://:change_this_redis_password@redis:6379

# ─── CRYPTOGRAPHIC SECRETS (Section 7.1 Security Assertions) ────────────────
# Minimum 32-character high-entropy secure hashes (e.g., openssl rand -hex 32)
JWT_SECRET=your_super_secret_jwt_sign_key_must_be_long_and_secure
JWT_REFRESH_SECRET=your_super_secret_jwt_refresh_sign_key_must_be_long_and_secure
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Storefront ISR on-demand revalidation shared secret (must match on both frontend & backend)
REVALIDATE_SECRET=rajshree_revalidate_secret_2026

# ─── RAZORPAY PAYMENT GATEWAY INTEGRATION (India-specific) ───────────────────
RAZORPAY_KEY_ID=rzp_live_your_active_key_id
RAZORPAY_KEY_SECRET=your_razorpay_api_secret_token
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_hash_secret

# ─── OPENAI AI LISTING ENHANCEMENT PIPELINE ──────────────────────────────────
OPENAI_API_KEY=sk-proj-your_active_openai_api_credential_key

# ─── SHIPROCKET LOGISTICS COURIER API ────────────────────────────────────────
# Production Shiprocket login credentials for serviceability and smart tracking
SHIPROCKET_EMAIL=shipping@rajshreejewels.com
SHIPROCKET_PASSWORD=your_secure_shiprocket_account_password

# India logistics pickup parameters
SHIPROCKET_PICKUP_LOCATION=Primary
SHIPROCKET_PICKUP_PINCODE=302001

# ─── MSG91 TRANSACTIONAL SMS GATEWAY (Jaipur & India Specific) ──────────────
MSG91_AUTH_KEY=your_msg91_auth_token_string
MSG91_SENDER_ID=RJSHRE
MSG91_TEMPLATE_ID_ORDER=your_order_placed_sms_template_id
MSG91_TEMPLATE_ID_SHIPPED=your_order_shipped_sms_template_id
MSG91_TEMPLATE_ID_DELIVERED=your_order_delivered_sms_template_id

# ─── TRANSACTIONAL EMAIL (SMTP) CONFIGURATION ────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=info@rajshreejewels.in
SMTP_PASS=your_gmail_app_specific_password_here
EMAIL_FROM="Rajshree Jewels <info@rajshreejewels.com>"

# ─── DYNAMIC STORE & SOCIAL MEDIA CONFIGURATIONS ─────────────────────────────
# Dynamic public branding variables used globally on storefront page shells.
# Note: Values default to blank or neutral layout states if omitted.
STORE_NAME="Rajshree Jewels"
STORE_TAGLINE="1-Gram Gold, Imitation & Fashion Jewellery"
STORE_PHONE=""
STORE_WHATSAPP=""
STORE_ADDRESS=""
STORE_INSTAGRAM=
STORE_FACEBOOK=

# NextAuth trust host
AUTH_TRUST_HOST=true

