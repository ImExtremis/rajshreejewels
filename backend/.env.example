# App
NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:3000
ADMIN_URL=http://localhost:3001

# Database
# Note: For running migrations from the host machine to Docker Postgres, we use localhost.
DATABASE_URL=postgresql://jewellery_user:change_this_strong_password@localhost:5432/jewellery_store
DB_USER=jewellery_user
DB_PASSWORD=change_this_strong_password

# Redis
REDIS_URL=redis://:change_this_redis_password@redis:6379
REDIS_PASSWORD=change_this_redis_password

# Auth
JWT_SECRET=change_this_64_char_random_string_very_long_and_secure_minimum_size_for_hmac
JWT_REFRESH_SECRET=change_this_different_64_char_random_string_very_long_and_secure_for_refresh
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Google OAuth
GOOGLE_CLIENT_ID=mock_client_id
GOOGLE_CLIENT_SECRET=mock_client_secret

# Razorpay
RAZORPAY_KEY_ID=rzp_test_mockkey
RAZORPAY_KEY_SECRET=mocksecret
RAZORPAY_WEBHOOK_SECRET=mockwebhooksecret

# OpenAI
OPENAI_API_KEY=mock_openai_key

# Shiprocket
SHIPROCKET_EMAIL=mock_email@store.com
SHIPROCKET_PASSWORD=mock_password

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=yourstore@gmail.com
SMTP_PASS=app_specific_password
EMAIL_FROM="Rajshree Jewels <yourstore@gmail.com>"

# SMS (MSG91)
MSG91_AUTH_KEY=mock_msg91_auth
MSG91_SENDER_ID=RJSHRE
MSG91_TEMPLATE_ID_ORDER=mock_order_template
MSG91_TEMPLATE_ID_SHIPPED=mock_shipped_template
MSG91_TEMPLATE_ID_DELIVERED=mock_delivered_template

# Store config
STORE_NAME="Rajshree Jewels"
STORE_TAGLINE="1-Gram Gold, Imitation & Fashion Jewellery"
